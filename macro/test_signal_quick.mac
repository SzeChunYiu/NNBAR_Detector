# Quick signal test - 10 events to see typical event structure
/run/initialize
/tracking/verbose 0
/physics_engine/neutron/timeLimit 10000 s

# Output folder
/particle_generator/set_folder_name test_signal_analysis
/particle_generator/set_run_number 0
/particle_generator/set_event_number 1

# Run 10 events
/run/beamOn 10
